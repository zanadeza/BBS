      "title": "The Skeletal System",
      "title_ar": "الجهاز الهيكلي",
      "topics": [
        {
          "term": "Bone",
          "term_ar": "عظم",
          "types": ["Long bones", "Short bones", "Flat bones", "Irregular bones", "Sesamoid bones"],
          "functions": ["Support", "Protection", "Movement", "Storage", "Blood cell formation"]
        },
        {
          "term": "Axial Skeleton",
          "term_ar": "الهيكل المحوري",
          "components": ["Skull (22 bones)", "Vertebral column (26 vertebrae)", "Rib cage (12 pairs)"]
        },
        {
          "term": "Appendicular Skeleton",
          "term_ar": "الهيكل الطرفي",
          "components": ["Upper extremities (64 bones)", "Lower extremities (62 bones)", "Shoulder girdle", "Pelvic girdle"]
        }
      ]
    },
    "chapter6": {
      "title": "The Muscular System",
      "title_ar": "الجهاز العضلي",
      "topics": [
        {
          "term": "Skeletal Muscle",
          "term_ar": "العضلة الهيكلية",
          "characteristics": ["Striated", "Voluntary", "Multinucleated"],
          "functions": ["Body movement", "Posture", "Heat production"]
        },
        {
          "term": "Sarcomere",
          "term_ar": "القسيم العضلي",
          "definition": "Structural and functional unit of muscle tissue",
          "definition_ar": "الوحدة التركيبية والوظيفية للنسيج العضلي",
          "components": ["Z-lines", "I-band", "A-band", "H-zone", "M-line"]
        },
        {
          "term": "Neuromuscular Junction",
          "term_ar": "الموصل العصبي العضلي",
          "definition": "The synapse between a neuron and a muscle cell",
          "definition_ar": "المشبك بين الخلية العصبية والخلية العضلية",
          "neurotransmitter": "Acetylcholine"
        }
      ]
    },
    "chapter7": {
