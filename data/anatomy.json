    "chapter1": {
      "title": "Introduction to Human Anatomy and Physiology",
      "title_ar": "مقدمة في تشريح ووظائف الأعضاء البشرية",
      "topics": [
        {
          "term": "Anatomy",
          "term_ar": "التشريح",
          "definition": "The science of body structures and the relationships among them",
          "definition_ar": "علم يدرس هياكل الجسم والعلاقات بينها",
          "examples": ["Gross anatomy", "Microscopic anatomy (Histology)"]
        },
        {
          "term": "Physiology",
          "term_ar": "وظائف الأعضاء",
          "definition": "The science of body function (how the body parts work)",
          "definition_ar": "علم يدرس وظائف الجسم (كيف تعمل أجزاء الجسم)"
        },
        {
          "term": "Levels of Structural Organization",
          "term_ar": "مستويات التنظيم التركيبي",
          "definition": "Atoms → Molecules → Cells → Tissues → Organs → Systems → Organism",
          "definition_ar": "ذرات → جزيئات → خلايا → أنسجة → أعضاء → أجهزة → كائن حي"
        }
      ]
    },
    "chapter2": {
      "title": "Cell Physiology",
      "title_ar": "فيزيولوجيا الخلية",
      "topics": [
        {
          "term": "Cell",
          "term_ar": "خلية",
          "definition": "The basic living structural and functional unit of the body",
          "definition_ar": "وحدة البناء والوظيفة الأساسية الحية في الجسم",
          "functions": ["Movement", "Conduction", "Absorption", "Secretion", "Excretion", "Respiration", "Reproduction"],
          "functions_ar": ["حركة", "توصيل", "امتصاص", "إفراز", "إخراج", "تنفس", "تكاثر"]
        },
        {
          "term": "Intracellular Fluid (ICF)",
          "term_ar": "السائل داخل الخلايا",
          "definition": "Approximately 2/3 of total body water",
          "definition_ar": "حوالي ثلثي إجمالي ماء الجسم"
        },
        {
          "term": "Extracellular Fluid (ECF)",
          "term_ar": "السائل خارج الخلايا",
          "definition": "Approximately 1/3 of total body water, includes interstitial fluid and intravascular fluid",
          "definition_ar": "حوالي ثلث إجمالي ماء الجسم، يشمل السائل الخلالي والسائل داخل الأوعية"
        }
      ]
    },
    "chapter3": {
      "title": "Tissues and Membranes",
      "title_ar": "الأنسجة والأغشية",
      "topics": [
        {
          "term": "Epithelial Tissue",
          "term_ar": "النسيج الطلائي",
          "definition": "Covers body surfaces and lines body cavities",
          "definition_ar": "يغطي أسطح الجسم ويبطن تجاويفه",
          "types": ["Simple squamous", "Stratified squamous", "Transitional", "Cuboidal", "Columnar", "Ciliated"]
        },
        {
          "term": "Connective Tissue",
          "term_ar": "النسيج الضام",
          "definition": "Connects and holds structures together, provides support and protection",
          "definition_ar": "يربط ويثبت الهياكل معاً، يوفر الدعم والحماية",
          "types": ["Bone", "Blood", "Cartilage", "Fibrous CT", "Adipose", "Reticular"]
        },
        {
          "term": "Muscle Tissue",
          "term_ar": "النسيج العضلي",
          "types": ["Skeletal", "Cardiac", "Smooth"]
        },
        {
          "term": "Nervous Tissue",
          "term_ar": "النسيج العصبي",
          "definition": "Excitable tissue capable of sending and receiving electrical signals",
          "definition_ar": "نسيج قابل للإثارة قادر على إرسال واستقبال الإشارات الكهربائية"
        }
      ]
    },
    "chapter4": {
      "title": "The Integumentary System",
      "title_ar": "الجهاز الجلدي",
      "topics": [
        {
          "term": "Skin",
          "term_ar": "الجلد",
          "definition": "The largest organ in the body which covers the entire surface of the human body",
          "definition_ar": "أكبر عضو في الجسم يغطي كامل سطح جسم الإنسان",
          "layers": ["Epidermis", "Dermis", "Hypodermis"],
          "functions": ["Protection", "Sensation", "Temperature Regulation", "Immunity", "Excretion", "Vitamin D synthesis"]
        },
        {
          "term": "Epidermis",
          "term_ar": "البشرة",
          "layers": ["Stratum corneum", "Stratum lucidum", "Stratum granulosum", "Stratum spinosum", "Stratum basale"]
        },
        {
          "term": "Melanin",
          "term_ar": "الميلانين",
          "definition": "Pigment that gives hair and skin its color and protects from UV radiation",
          "definition_ar": "صبغة تعطي الشعر والجلد لونهما وتحمي من الأشعة فوق البنفسجية"
        }
      ]
    },
